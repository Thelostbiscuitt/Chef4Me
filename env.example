# ============================
# Telegram Bot Configuration
# ============================
# Get from @BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ============================
# Google Gemini AI
# ============================
# Get from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# ============================
# Notion Integration (Optional)
# ============================
# Get from https://www.notion.so/my-integrations
NOTION_TOKEN=your_notion_token_here
NOTION_INGREDIENTS_DB=
NOTION_RECIPES_DB=
NOTION_SYNC_INTERVAL=300

# ============================
# Bot Settings
# ============================
SUGGESTIONS_PER_REQUEST=6
EXPIRY_CHECK_INTERVAL=3600
EXPIRY_WARNING_DAYS=2
LOG_LEVEL=INFO

# ============================
# Webhook Settings
# ============================
# Your Render service public URL (no trailing slash).
# Render also sets RENDER_EXTERNAL_URL automatically — you can use that instead.
WEBHOOK_BASE_URL=https://your-service-name.onrender.com

# Optional: override the webhook path (default uses your bot token, which is safe)
# WEBHOOK_PATH=/webhook/your_bot_token

# A random secret string for the X-Telegram-Bot-Api-Secret-Token header.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=generate_a_random_string_here

# Port (Render sets this automatically — leave blank locally or set to 8080)
# PORT=8080
